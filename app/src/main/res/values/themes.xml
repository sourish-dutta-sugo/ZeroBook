<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZeroBook"
        parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">
            @android:color/transparent
        </item>
    </style>

    <style name="Theme.ZeroBook.Splash"
        parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">
            #FAF8F5
        </item>
        <item name="windowSplashScreenAnimatedIcon">
            @null
        </item>
        <item name="windowSplashScreenIconBackgroundColor">
            #FAF8F5
        </item>
        <item name="postSplashScreenTheme">
            @style/Theme.ZeroBook
        </item>
    </style>
</resources>
